# WebSocket Server Environment Configuration

# Environment mode: 'development' or 'production'
NODE_ENV=development

# Production settings (only used when NODE_ENV=production)
# Note: Render.com will use PORT env variable automatically
WS_PORT=3000
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# For Render.com deployment, set these in the Render dashboard:
# - NODE_ENV=production
# - CORS_ORIGINS=https://vase-domena.cz,https://www.vase-domena.cz
# (PORT is set automatically by Render)
